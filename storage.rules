rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/menu-items/{itemId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
