rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userDoc());
    }

    function userData() {
      return get(userDoc()).data;
    }

    function userRole() {
      return userExists() ? userData().role : null;
    }

    function assignedStores() {
      return userExists()
        ? (userData().assignedStores is list ? userData().assignedStores : [])
        : [];
    }

    function isAdmin() {
      return userRole() in ["SUPER_ADMIN", "ADMIN"];
    }

    function canManageProducts() {
      return userRole() in ["SUPER_ADMIN", "ADMIN", "STORE_MANAGER", "STORE_OFFICER"];
    }

    function canManageStock() {
      return userRole() in ["SUPER_ADMIN", "ADMIN", "STORE_MANAGER", "STORE_OFFICER", "SUPERVISOR"];
    }

    function canManageSuppliers() {
      return userRole() in ["SUPER_ADMIN", "ADMIN", "STORE_MANAGER"];
    }

    function canManageRecipients() {
      return userRole() in ["SUPER_ADMIN", "ADMIN", "STORE_MANAGER"];
    }

    function canReadAuditLogs() {
      return isAdmin() || userRole() in ["SUPERVISOR", "AUDITOR"];
    }

    function canViewOrders() {
      return userRole() in ["SUPER_ADMIN", "ADMIN", "STORE_MANAGER", "STORE_OFFICER", "SUPERVISOR", "AUDITOR"];
    }

    function canManageOrders() {
      return userRole() in ["SUPER_ADMIN", "ADMIN", "STORE_MANAGER", "STORE_OFFICER", "SUPERVISOR"];
    }

    function hasStoreAccess(storeId) {
      return isAdmin() || assignedStores().size() == 0 || (storeId is string && storeId in assignedStores());
    }

    function hasCreateTimestamps() {
      return request.resource.data.createdAt == request.time && request.resource.data.updatedAt == request.time;
    }

    function hasUpdateTimestamp() {
      return request.resource.data.updatedAt == request.time;
    }

    function isNumeric(value) {
      return value is int || value is float;
    }

    function validStoreProductData() {
      return request.resource.data.storeId is string
        && request.resource.data.productId is string
        && request.resource.data.productName is string
        && request.resource.data.unit is string
        && request.resource.data.quantityOnHand is int
        && request.resource.data.quantityOnHand >= 0
        && request.resource.data.reorderLevel is int
        && request.resource.data.reorderLevel >= 0
        && isNumeric(request.resource.data.unitCost)
        && isNumeric(request.resource.data.totalValue)
        && request.resource.data.isActive is bool;
    }

    function validStockMovementData() {
      return request.resource.data.type in ["RECEIVE", "ISSUE", "TRANSFER", "ADJUSTMENT", "DAMAGE", "EXPIRY"]
        && request.resource.data.storeId is string
        && request.resource.data.productId is string
        && request.resource.data.productName is string
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && request.resource.data.unit is string
        && isNumeric(request.resource.data.unitCost)
        && isNumeric(request.resource.data.totalCost)
        && request.resource.data.status == "COMPLETED"
        && request.resource.data.performedBy == request.auth.uid;
    }

    function validAuditLogData() {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.userName is string
        && request.resource.data.action is string
        && request.resource.data.description is string
        && request.resource.data.createdAt == request.time;
    }

    function isMealRole() {
      return userRole() in ["NURSE", "KITCHEN_STAFF", "SUPER_ADMIN", "ADMIN"];
    }

    function isKitchenOrAdmin() {
      return userRole() in ["KITCHEN_STAFF", "SUPER_ADMIN", "ADMIN"];
    }

    function isNurse() {
      return userRole() == "NURSE";
    }

    function assignedWards() {
      return userExists()
        ? (userData().assignedWards is list ? userData().assignedWards : [])
        : [];
    }

    function canManageMenu() {
      return userRole() in ["SUPER_ADMIN", "ADMIN"];
    }

    function validMenuItemData() {
      return request.resource.data.name is string
        && request.resource.data.price is number
        && request.resource.data.isActive is bool;
    }

    function validFoodOrderData() {
      return request.resource.data.customerName is string
        && request.resource.data.phone is string
        && request.resource.data.deliveryLocation is string
        && request.resource.data.items is list
        && request.resource.data.status == "PENDING"
        && request.resource.data.paymentStatus == "PENDING";
    }

    function validPublicTrackingData() {
      return request.resource.data.orderId is string
        && request.resource.data.orderNumber is string
        && request.resource.data.customerName is string
        && request.resource.data.status is string
        && request.resource.data.items is list;
    }

    match /settings/{settingId} {
      allow read: if settingId == "orderSettings" || settingId == "vipMenu"
        || (signedIn() && isAdmin())
        || (signedIn() && settingId == "mealOrdering" && isMealRole());
      allow write: if signedIn() && isAdmin();
    }

    match /menuItems/{itemId} {
      allow read: if resource.data.isActive == true || (signedIn() && canManageMenu());
      allow create: if signedIn() && canManageMenu() && validMenuItemData();
      allow update: if signedIn() && canManageMenu() && validMenuItemData();
      allow delete: if signedIn() && canManageMenu();
    }

    match /foodOrders/{orderId} {
      allow read: if signedIn() && canViewOrders();
      allow create: if validFoodOrderData();
      allow update: if signedIn() && canManageOrders();
      allow delete: if signedIn() && isAdmin();
    }

    match /publicOrderTracking/{trackingId} {
      allow read: if true;
      allow create: if validPublicTrackingData();
      allow update: if signedIn() && canManageOrders();
      allow delete: if signedIn() && canManageOrders();
    }

    match /orderStatusLogs/{logId} {
      allow read: if signedIn() && canViewOrders();
      allow create: if signedIn() && canManageOrders()
        && request.resource.data.orderId is string
        && request.resource.data.previousStatus is string
        && request.resource.data.newStatus is string
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    // ── Meal Ordering ─────────────────────────────────────────────────────────

    match /wards/{wardId} {
      allow read: if signedIn() && isMealRole();
      allow create: if signedIn() && isAdmin();
      allow update: if signedIn() && isAdmin();
      allow delete: if signedIn() && isAdmin();
    }

    match /patients/{patientId} {
      allow read: if signedIn() && isMealRole();
      allow create: if signedIn() && isMealRole()
        && request.resource.data.patientName is string
        && request.resource.data.wardId is string
        && request.resource.data.bedNumber is string
        && request.resource.data.patientClass is string
        && request.resource.data.isSpecialPatient is bool
        && request.resource.data.specialMealType is string
        && request.resource.data.specialInstructions is string
        && request.resource.data.status is string;
      allow update: if signedIn() && isMealRole()
        && request.resource.data.patientName is string
        && request.resource.data.wardId is string
        && request.resource.data.bedNumber is string
        && request.resource.data.patientClass is string
        && request.resource.data.isSpecialPatient is bool
        && request.resource.data.specialMealType is string
        && request.resource.data.specialInstructions is string
        && request.resource.data.status is string;
      allow delete: if signedIn() && isAdmin();
    }

    match /mealMenus/{menuId} {
      allow read: if signedIn() && isMealRole();
      allow create: if signedIn() && canManageMenu();
      allow update: if signedIn() && canManageMenu();
      allow delete: if signedIn() && isAdmin();
    }

    match /wardMealOrders/{orderId} {
      allow read: if signedIn() && isMealRole();
      allow create: if signedIn() && isMealRole()
        && request.resource.data.patientId is string
        && request.resource.data.wardId is string
        && request.resource.data.mealPeriod in ["BREAKFAST","LUNCH","SUPPER"]
        && request.resource.data.status == "REQUESTED";
      allow update: if signedIn() && isMealRole();
      allow delete: if signedIn() && isAdmin();
    }

    match /mealOrderStatusLogs/{logId} {
      allow read: if signedIn() && isMealRole();
      allow create: if signedIn() && isMealRole()
        && request.resource.data.orderId is string
        && request.resource.data.newStatus is string;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if signedIn() && (isAdmin() || request.auth.uid == userId);
      allow create: if signedIn() && isAdmin() && hasCreateTimestamps();
      allow update: if signedIn() && isAdmin() && hasUpdateTimestamp();
      allow delete: if signedIn() && isAdmin();
    }

    match /stores/{storeId} {
      allow read: if signedIn();
      allow create: if signedIn() && isAdmin() && hasCreateTimestamps();
      allow update: if signedIn() && isAdmin() && hasUpdateTimestamp();
      allow delete: if signedIn() && isAdmin();
    }

    match /products/{productId} {
      allow read: if signedIn();
      allow create: if signedIn() && canManageProducts() && hasCreateTimestamps()
        && request.resource.data.name is string
        && request.resource.data.normalizedName is string
        && request.resource.data.unit is string
        && request.resource.data.isActive is bool;
      allow update: if signedIn() && canManageProducts() && hasUpdateTimestamp()
        && request.resource.data.name is string
        && request.resource.data.normalizedName is string
        && request.resource.data.unit is string
        && request.resource.data.isActive is bool;
      allow delete: if signedIn() && isAdmin();
    }

    match /productCategories/{categoryId} {
      allow read: if signedIn();
      allow create: if signedIn() && isAdmin() && hasCreateTimestamps()
        && request.resource.data.name is string
        && request.resource.data.isActive is bool;
      allow update: if signedIn() && isAdmin() && hasUpdateTimestamp()
        && request.resource.data.name is string
        && request.resource.data.isActive is bool;
      allow delete: if signedIn() && isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if signedIn();
      allow create: if signedIn() && canManageSuppliers() && hasCreateTimestamps()
        && request.resource.data.name is string
        && request.resource.data.isActive is bool;
      allow update: if signedIn() && canManageSuppliers() && hasUpdateTimestamp()
        && request.resource.data.name is string
        && request.resource.data.isActive is bool;
      allow delete: if signedIn() && isAdmin();
    }

    match /recipients/{recipientId} {
      allow read: if signedIn();
      allow create: if signedIn() && canManageRecipients() && hasCreateTimestamps()
        && request.resource.data.name is string
        && request.resource.data.type is string
        && request.resource.data.isActive is bool;
      allow update: if signedIn() && canManageRecipients() && hasUpdateTimestamp()
        && request.resource.data.name is string
        && request.resource.data.type is string
        && request.resource.data.isActive is bool;
      allow delete: if signedIn() && isAdmin();
    }

    match /storeProducts/{storeProductId} {
      allow read: if signedIn() && hasStoreAccess(resource.data.storeId);
      allow create: if signedIn() && canManageStock() && hasStoreAccess(request.resource.data.storeId)
        && hasCreateTimestamps()
        && validStoreProductData();
      allow update: if signedIn() && canManageStock() && hasStoreAccess(resource.data.storeId)
        && hasUpdateTimestamp()
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.productId == resource.data.productId
        && validStoreProductData();
      allow delete: if signedIn() && isAdmin();
    }

    match /stockMovements/{movementId} {
      allow read: if signedIn() && (
        canReadAuditLogs() ||
        hasStoreAccess(resource.data.storeId)
      );
      allow create: if signedIn() && canManageStock() && hasStoreAccess(request.resource.data.storeId)
        && hasCreateTimestamps()
        && validStockMovementData();
      allow update: if signedIn() && isAdmin() && hasUpdateTimestamp();
      allow delete: if signedIn() && isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if signedIn() && (
        canReadAuditLogs() ||
        hasStoreAccess(resource.data.storeId)
      );
      allow create: if signedIn() && validAuditLogData();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
